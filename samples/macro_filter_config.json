  "python_example": {
    "description": "Example of how to load and apply a macro filter configuration",
    "code": [
      "import json",
      "from indicator_collector.trading_system import SignalGenerator, SignalConfig",
      "",
      "# Load configuration",
      "with open('samples/macro_filter_config.json') as f:",
      "    config_data = json.load(f)",
      "",
      "# Select high volatility config",
      "high_vol_config = config_data['configurations']['high_volatility']",
      "",
      "# Create SignalConfig from dict",
      "config = SignalConfig(",
      "    technical_weight=high_vol_config['technical_weight'],",
      "    sentiment_weight=high_vol_config['sentiment_weight'],",
      "    multitimeframe_weight=high_vol_config['multitimeframe_weight'],",
      "    volume_weight=high_vol_config['volume_weight'],",
      "    structure_weight=high_vol_config['structure_weight'],",
      "    composite_weight=high_vol_config['composite_weight'],",
      "    buy_threshold=high_vol_config['buy_threshold'],",
      "    sell_threshold=high_vol_config['sell_threshold'],",
      "    min_factors_confirm=high_vol_config['min_factors_confirm'],",
      "    max_risk_score=high_vol_config['max_risk_score'],",
      "    min_liquidity_score=high_vol_config['min_liquidity_score'],",
      "    max_volatility_ratio=high_vol_config['max_volatility_ratio'],",
      ")",
      "",
      "# Create generator with config",
      "generator = SignalGenerator(config=config)",
      "",
      "# Use generator as normal",
      "signal = generator.generate_signal(context)"
    ]
