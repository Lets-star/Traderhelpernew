{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trading Signal Payload",
  "description": "Complete trading signal generated by the automated trading system",
  "type": "object",
  "required": [
    "signal_type",
    "confidence",
    "timestamp",
    "factors",
    "position_plan",
    "explanation"
  ],
  "properties": {
    "signal_type": {
      "type": "string",
      "enum": ["BUY", "SELL", "NEUTRAL"],
      "description": "Type of trading signal"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence level of the signal (0.0 to 1.0)"
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds when signal was generated"
    },
    "factors": {
      "type": "array",
      "description": "Individual factors contributing to the signal",
      "items": {
        "$ref": "#/definitions/FactorScore"
      }
    },
    "position_plan": {
      "$ref": "#/definitions/PositionPlan",
      "description": "Suggested position entry, SL, and TP levels"
    },
    "explanation": {
      "$ref": "#/definitions/SignalExplanation",
      "description": "Rationale and context for the signal"
    },
    "optimization_stats": {
      "$ref": "#/definitions/OptimizationStats",
      "description": "Historical performance metrics for this signal type"
    },
    "cancellation_triggers": {
      "type": "array",
      "description": "Reasons why the signal might be cancelled",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "FactorScore": {
      "type": "object",
      "required": ["factor_name", "score", "weight"],
      "properties": {
        "factor_name": {
          "type": "string",
          "description": "Name of the factor (e.g., 'rsi_oversold', 'macd_bullish')"
        },
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0,
          "description": "Factor score (0-100)"
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "description": "Weight of this factor in the final signal (higher = more important)"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Human-readable description of the factor"
        },
        "emoji": {
          "type": ["string", "null"],
          "description": "Emoji indicator (e.g., '🟢' for bullish, '🔴' for bearish)"
        },
        "metadata": {
          "type": "object",
          "description": "Additional factor-specific data"
        }
      }
    },
    "PositionPlan": {
      "type": "object",
      "properties": {
        "entry_price": {
          "type": "number",
          "description": "Suggested entry price"
        },
        "stop_loss_price": {
          "type": ["number", "null"],
          "description": "Suggested stop loss price"
        },
        "take_profit_levels": {
          "type": ["array", "null"],
          "description": "Array of take profit levels for scaling out",
          "items": {
            "type": "number"
          }
        },
        "position_size_usd": {
          "type": ["number", "null"],
          "description": "Suggested position size in USD"
        },
        "leverage": {
          "type": ["number", "null"],
          "description": "Suggested leverage multiplier"
        },
        "direction": {
          "type": ["string", "null"],
          "enum": ["LONG", "SHORT", null],
          "description": "Position direction"
        },
        "risk_reward_ratio": {
          "type": ["number", "null"],
          "description": "Risk/reward ratio of the position"
        },
        "max_risk_pct": {
          "type": ["number", "null"],
          "description": "Maximum risk as percentage of account"
        }
      }
    },
    "SignalExplanation": {
      "type": "object",
      "properties": {
        "primary_reason": {
          "type": ["string", "null"],
          "description": "Main reason for the signal"
        },
        "supporting_factors": {
          "type": ["array", "null"],
          "description": "List of supporting factors",
          "items": {
            "type": "string"
          }
        },
        "risk_factors": {
          "type": ["array", "null"],
          "description": "List of identified risks",
          "items": {
            "type": "string"
          }
        },
        "market_context": {
          "type": ["string", "null"],
          "description": "Current market conditions"
        }
      }
    },
    "OptimizationStats": {
      "type": "object",
      "properties": {
        "backtest_win_rate": {
          "type": ["number", "null"],
          "description": "Historical win rate percentage"
        },
        "avg_profit_pct": {
          "type": ["number", "null"],
          "description": "Average profit per winning trade (%)"
        },
        "avg_loss_pct": {
          "type": ["number", "null"],
          "description": "Average loss per losing trade (%)"
        },
        "sharpe_ratio": {
          "type": ["number", "null"],
          "description": "Sharpe ratio of the strategy"
        },
        "profit_factor": {
          "type": ["number", "null"],
          "description": "Ratio of gross profit to gross loss"
        },
        "total_signals": {
          "type": ["integer", "null"],
          "description": "Total number of signals in backtest"
        },
        "profitable_signals": {
          "type": ["integer", "null"],
          "description": "Number of profitable signals"
        },
        "losing_signals": {
          "type": ["integer", "null"],
          "description": "Number of losing signals"
        }
      }
    }
  }
}
